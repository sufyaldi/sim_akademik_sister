<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sister_config_form" model="ir.ui.view">
        <field name="name">sister.config.form</field>
        <field name="model">sister.config</field>
        <field name="arch" type="xml">
            <form string="SISTER Configuration">
                <header>
                    <button name="action_get_token" string="Generate Token (Login)" type="object" class="btn-success" icon="fa-key"/>
                    <button name="action_get_referensi_pt" string="Tarik Referensi PT" type="object" class="btn-primary" icon="fa-university" invisible="not api_token"/>
                    <button name="action_sync_sdm_referensi" string="Tarik Referensi SDM (Dosen)" type="object" class="oe_highlight" icon="fa-users" invisible="not api_token"/>
                    <button name="action_test_connection" string="Uji Koneksi API" type="object" class="btn-secondary" icon="fa-wifi"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="is_active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="E.g. Production SISTER API"/>
                        </h1>
                    </div>
                    <group>
                        <group string="API Details">
                            <field name="base_url"/>
                            <field name="api_token" password="1"/>
                        </group>
                        <group string="Credentials">
                            <field name="id_pengguna" placeholder="Contoh: a1b2c3d4-e5f6-7890-..."/>
                            <field name="username"/>
                            <field name="password" password="1"/>
                            <field name="is_active" invisible="1"/>
                        </group>
                    </group>
                    <group string="Identitas Perguruan Tinggi">
                        <field name="id_pt"/>
                        <field name="nama_pt"/>
                    </group>
                    <group string="Sync Information">
                        <field name="last_sync_time"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sister_config_tree" model="ir.ui.view">
        <field name="name">sister.config.tree</field>
        <field name="model">sister.config</field>
        <field name="arch" type="xml">
            <list string="SISTER Configurations">
                <field name="name"/>
                <field name="base_url"/>
                <field name="is_active" widget="boolean_toggle"/>
                <field name="last_sync_time"/>
            </list>
        </field>
    </record>

    <record id="action_sister_config" model="ir.actions.act_window">
        <field name="name">SISTER Config</field>
        <field name="res_model">sister.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_sister_root" name="SISTER Sync" sequence="100"/>
    <menuitem id="menu_sister_config" name="Configuration" parent="menu_sister_root" action="action_sister_config" sequence="90"/>
</odoo>
