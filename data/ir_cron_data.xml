<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron Job untuk sinkron otomatis setiap jam 01:00 pagi -->
        <record id="ir_cron_sister_sync_massal" model="ir.cron">
            <field name="name">SISTER: Sinkronisasi Massal Tridharma Dosen</field>
            <field name="model_id" ref="sim_akademik_sister.model_sister_config"/>
            <field name="state">code</field>
            <field name="code">model.action_cron_sync_all_sister_data()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
